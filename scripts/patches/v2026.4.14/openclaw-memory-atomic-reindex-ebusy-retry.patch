+// LobsterAI patch: Windows EBUSY retry for atomic memory reindex (openclaw#64187).
+// SQLite WAL-mode holds file locks that cause fs.rename() to fail with EBUSY on
+// Windows.  Retry with exponential back-off and fall back to copy+unlink for
+// EPERM/EEXIST, mirroring the pattern already used in src/cron/store.ts.
+const RENAME_MAX_RETRIES = 3;
+const RENAME_BASE_DELAY_MS = 50;
+
+async function renameWithRetry(src: string, dest: string): Promise<void> {
+  for (let attempt = 0; attempt <= RENAME_MAX_RETRIES; attempt++) {
+    try {
+      await fs.rename(src, dest);
+      return;
+    } catch (err) {
+      const code = (err as { code?: string }).code;
+      if (code === "EBUSY" && attempt < RENAME_MAX_RETRIES) {
+        await new Promise((resolve) => setTimeout(resolve, RENAME_BASE_DELAY_MS * 2 ** attempt));
+        continue;
+      }
+      // Windows doesn't reliably support atomic replace via rename when dest exists.
+      if (code === "EPERM" || code === "EEXIST") {
+        await fs.copyFile(src, dest);
+        await fs.unlink(src).catch(() => {});
+        return;
+      }
+      throw err;
+    }
+  }
+}
